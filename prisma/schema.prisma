generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Admin {
  id             Int      @id @default(autoincrement())
  name           String?
  email          String   @unique
  password_hash  String
  remember_token String?
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt
  avatar_url     String?
}

model Project {
  id          Int                  @id @default(autoincrement())
  title       String
  description String?
  slug        String               @unique
  project_url String?
  is_featured Boolean              @default(false)
  created_at  DateTime             @default(now())
  updated_at  DateTime             @updatedAt
  categories  ProjectCategoryRel[]
  details     ProjectDetail?
  features    ProjectFeature[]
  images      ProjectImage[]
  techs       ProjectTechRel[]
}

model ProjectImage {
  id         Int     @id @default(autoincrement())
  image_url  String
  is_primary Boolean @default(false)
  project_id Int
  project    Project @relation(fields: [project_id], references: [id], onDelete: Cascade)
}

model ProjectDetail {
  id         Int     @id @default(autoincrement())
  problem    String?
  solution   String?
  project_id Int     @unique
  project    Project @relation(fields: [project_id], references: [id], onDelete: Cascade)
}

model ProjectFeature {
  id         Int     @id @default(autoincrement())
  content    String
  project_id Int
  project    Project @relation(fields: [project_id], references: [id], onDelete: Cascade)
}

model Tech {
  id       Int              @id @default(autoincrement())
  name     String           @unique
  projects ProjectTechRel[]
}

model ProjectTechRel {
  project_id Int
  tech_id    Int
  project    Project @relation(fields: [project_id], references: [id], onDelete: Cascade)
  tech       Tech    @relation(fields: [tech_id], references: [id])

  @@id([project_id, tech_id])
}

model Category {
  id             Int                        @id @default(autoincrement())
  name           String
  slug           String                     @unique
  certifications CertificationCategoryRel[]
  projects       ProjectCategoryRel[]
}

model CertificationCategoryRel {
  certification_id Int
  category_id      Int
  category         Category      @relation(fields: [category_id], references: [id], onDelete: Cascade)
  certification    Certification @relation(fields: [certification_id], references: [id], onDelete: Cascade)

  @@id([certification_id, category_id])
}

model ProjectCategoryRel {
  project_id  Int
  category_id Int
  category    Category @relation(fields: [category_id], references: [id], onDelete: Cascade)
  project     Project  @relation(fields: [project_id], references: [id], onDelete: Cascade)

  @@id([project_id, category_id])
}

model Certification {
  id          Int                        @id @default(autoincrement())
  title       String
  issuer      String?
  description String?
  slug        String                     @unique
  source_url  String?
  is_featured Boolean                    @default(false)
  created_at  DateTime                   @default(now())
  updated_at  DateTime                   @updatedAt
  year        Int?
  categories  CertificationCategoryRel[]
  images      CertificationImage[]
  skills      CertificationSkill[]
}

model CertificationImage {
  id               Int           @id @default(autoincrement())
  image_url        String
  certification_id Int
  certification    Certification @relation(fields: [certification_id], references: [id], onDelete: Cascade)
}

model CertificationSkill {
  id               Int           @id @default(autoincrement())
  skill            String
  certification_id Int
  certification    Certification @relation(fields: [certification_id], references: [id], onDelete: Cascade)
}

model Experience {
  id              Int               @id @default(autoincrement())
  title           String
  company         String?
  start_date      DateTime?
  end_date        DateTime?
  description     String?
  type            String?
  certificate_url String?
  created_at      DateTime          @default(now())
  updated_at      DateTime          @updatedAt
  points          ExperiencePoint[]
}

model ExperiencePoint {
  id            Int        @id @default(autoincrement())
  content       String
  experience_id Int
  experience    Experience @relation(fields: [experience_id], references: [id], onDelete: Cascade)
}
