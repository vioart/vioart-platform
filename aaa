<FormMultiSelector
  label="Kategori"
  items={categories}
  selected={techCat.selectedCategories}
  onToggle={techCat.toggleCategory}
  isSelected={techCat.isCategorySelected}
/>

<FormMultiSelector
  label="Kategori"
  items={categories}
  selected={techCat.selectedCategories}
  onToggle={techCat.toggleCategory}
  isSelected={techCat.isCategorySelected}
/>

<FormListField
  title="Fitur Project"
  description="Tambahkan fitur utama dari project ini"
  items={feature.features}
  onAdd={feature.addFeature}
  onRemove={feature.removeFeature}
  onChange={feature.updateFeature}
  labelPrefix="Fitur"
  placeholder="Contoh: Sistem login dengan JWT"
/>

<FormListField
  title="Skill"
  items={skills}
  onAdd={addSkill}
  onRemove={removeSkill}
  onChange={updateSkill}
  labelPrefix="Skill"
/>

<FormListField
  title="Poin Pengalaman"
  items={points}
  onAdd={addPoint}
  onRemove={removePoint}
  onChange={updatePoint}
  labelPrefix="Poin"
/>




<FormImageUpload
  title="Media Project"
  images={image.images}
  setPrimary={image.setPrimary}
  remove={image.remove}
  onUpload={image.handleUpload}
  onDrop={image.handleDrop}
/>

<FormImageUpload
  title="Gambar Sertifikat"
  images={image.images}
  setPrimary={image.setPrimary}
  remove={image.remove}
  onUpload={image.handleUpload}
  onDrop={image.handleDrop}
/>



<FormSwitch
  label="Tampilkan sebagai Unggulan"
  description="Project akan ditampilkan di bagian utama"
  checked={form.isFeatured}
  onChange={form.setIsFeatured}
/>

<FormSwitch
  label="Sertifikat Unggulan"
  description="Akan ditampilkan di highlight"
  checked={form.isFeatured}
  onChange={form.setIsFeatured}
/>



<FormTextarea
  label="Deskripsi Project"
  value={form.description}
  onChange={form.setDescription}
  placeholder="Jelaskan tentang project ini..."
/>


<FormTextarea
  label="Deskripsi Sertifikat"
  value={form.description}
  onChange={form.setDescription}
/>




<FormField
  label="URL Project"
  value={form.url}
  onChange={form.setUrl}
  placeholder="https://example.com"
/>

<FormField
  label="Sumber Sertifikat"
  value={form.source_url}
  onChange={form.setSourceUrl}
/>





<FormGridField
  left={{
    label: "Judul Project",
    value: form.title,
    onChange: form.handleTitleChange,
  }}
  right={{
    label: "Slug",
    value: form.slug,
    onChange: form.setSlug,
  }}
/>

<FormGridField
  left={{
    label: "Judul Sertifikat",
    value: form.title,
    onChange: form.setTitle,
  }}
  right={{
    label: "Issuer",
    value: form.issuer,
    onChange: form.setIssuer,
  }}
/>